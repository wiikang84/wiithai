rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /wiiinfoPhrases/{phraseId} {
      allow read: if true;
      allow write: if false;
    }

    match /places/{placeId} {
      allow read: if true;
      allow write: if false;
    }

    match /coupons/{couponId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow read: if signedInOwner(userId);
      allow create, update: if signedInOwner(userId) && validUserProfile();
      allow delete: if false;
    }

    function signedInOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function validUserProfile() {
      return request.resource.data.keys().hasOnly([
        "uid",
        "email",
        "displayName",
        "photoURL",
        "favoriteIds",
        "savedPlaceIds",
        "nationality",
        "preferredLang",
        "preferredFrom",
        "preferredLearn",
        "createdAt",
        "updatedAt",
        "lastLoginAt"
      ])
      && request.resource.data.uid == request.auth.uid
      && optionalString("email", 320)
      && optionalString("displayName", 120)
      && optionalString("photoURL", 1000)
      && optionalString("nationality", 40)
      && optionalString("preferredLang", 20)
      && optionalString("preferredFrom", 20)
      && optionalString("preferredLearn", 20)
      && optionalFavorites()
      && optionalSavedPlaces()
      && optionalTimestamp("createdAt")
      && optionalTimestamp("updatedAt")
      && optionalTimestamp("lastLoginAt");
    }

    function optionalString(field, maxLength) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is string && request.resource.data[field].size() <= maxLength);
    }

    function optionalFavorites() {
      return !("favoriteIds" in request.resource.data)
        || (request.resource.data.favoriteIds is list && request.resource.data.favoriteIds.size() <= 500);
    }

    function optionalSavedPlaces() {
      return !("savedPlaceIds" in request.resource.data)
        || (request.resource.data.savedPlaceIds is list && request.resource.data.savedPlaceIds.size() <= 500);
    }

    function optionalTimestamp(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] is timestamp;
    }
  }
}

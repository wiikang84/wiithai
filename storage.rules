rules_version = '2';

// [2026-06-18] 사장님 등록 신청 서류(사업자등록증 등) 보관.
// 본인만 업로드, 운영자(master)만 열람 — 사업자등록증은 개인정보라 일반 공개 금지.
service firebase.storage {
  match /b/{bucket}/o {

    // 사장님 신청 첨부 서류: owner-docs/{uid}/{claimId}/{fileName}
    match /owner-docs/{uid}/{allPaths=**} {
      allow read: if isMaster();
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType == 'application/pdf');
    }

    // [2026-06-22] §3 현장 등록 가게 사진: store-photos/{uid}/{fileName}.
    //   손님 화면에 노출되므로 read 공개. 업로드는 로그인 사용자(본인 폴더), 이미지 2MB 이하만(클라 리사이즈 후).
    //   가게 doc에 사진 URL을 박는 건 master/supervisor만 가능(firestore stores 규칙)하므로 임의 업로드는 노출되지 않음.
    match /store-photos/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // 그 외 경로는 기본 차단
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }

  function isMaster() {
    return request.auth != null && request.auth.token.email in [
      'dy17715@naver.com', 'tmzkt2@gmail.com', 'ironyjk@gmail.com', 'dylab177151@gmail.com'
    ];
  }
}
